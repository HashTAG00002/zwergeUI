      osworld-g_two_stage.py   # OSWorld-G two-stage eval
      mmbench_gui_l2.py        # MMBench GUI L2 eval
      plot_probe.py            # layer_probe 结果可视化
    scripts/
      sft_single_node.sh       # 单机 SFT 训练
      sft_multi_node.sh        # 多机 SFT 训练
