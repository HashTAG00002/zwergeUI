## Phase 5：正式 Layer-wise Retrofit Head

### 目标

实现 shared projection head + layer-specific adapter + learned fusion。

### 模块

```python
class LayerWiseGroundingHead(nn.Module):
    def __init__(
        self,
        d_model,
        d_proj,
        selected_layers,
        adapter_rank,
    ):
        self.q_proj = MLP(d_model, d_proj)
        self.k_proj = MLP(d_model, d_proj)

        self.q_adapters = LayerSpecificLoRA(
            selected_layers, d_model, adapter_rank
        )
        self.k_adapters = LayerSpecificLoRA(
            selected_layers, d_model, adapter_rank
        )

        self.layer_embeddings = nn.Embedding(
            len(selected_layers), d_layer_emb
        )

        self.fusion_mlp = MLP(readiness_dim + d_layer_emb, 1)
        self.pos_bias = PositionalBias2D(...)
```

### Forward

```python
all_p = []
all_scores = []

for layer_id in selected_layers:
    h_vis = hidden_states[layer_id][:, visual_indices, :]
    h_q = hidden_states[layer_id][:, query_token_idx, :]

    h_vis = ln_v[layer_id](h_vis)
    h_q = ln_q[layer_id](h_q)

    h_vis = h_vis + k_adapters[layer_id](h_vis)
    h_q = h_q + q_adapters[layer_id](h_q)

    q = q_proj(h_q)
    k = k_proj(h_vis)

    logits = dot(q, k) / sqrt(d_proj) + pos_bias
    p_l = softmax(logits, dim=-1)

    feat_l = compute_readiness_features(p_l)
    score_l = fusion_mlp(concat(feat_l, layer_embedding[layer_id]))

    all_p.append(p_l)
    all_scores.append(score_l)

omega = softmax(stack(all_scores), dim=layer_dim)
p_final = sum(omega_l * p_l for omega_l, p_l in zip(omega, all_p))
```

### Loss

```python
loss_fuse = KL(label, p_final)
loss_layer = sum(alpha_l * KL(label, p_l))
loss = loss_fuse + lambda_layer * loss_layer
```

