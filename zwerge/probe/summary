## 7.1 `import_upstream.py`

功能：动态加载上游 `layer_probe.py`。

```python
# probe_patch/import_upstream.py

from importlib.machinery import SourceFileLoader
from pathlib import Path
import sys

def load_layer_probe(repo_root: str):
    repo_root = Path(repo_root).resolve()
    gui_aima_root = repo_root / "GUI-AIMA"
    eval_file = gui_aima_root / "eval" / "layer_probe.py"

    if not eval_file.exists():
        raise FileNotFoundError(f"Cannot find layer_probe.py: {eval_file}")

    sys.path.insert(0, str(gui_aima_root))
    module = SourceFileLoader("zwerge_upstream_layer_probe", str(eval_file)).load_module()
    return module
```

