## 7.3 `metrics.py`

实现所有基础指标：

```python
def scores_to_prob(scores, mode="auto", temperature=1.0):
    """
    mode=auto:
    - if scores are non-negative and sum positive: normalize
    - otherwise: softmax
    """

def normalized_entropy(p):
    return -(p * (p + 1e-12).log()).sum() / math.log(p.numel())

def margin(p):
    top2 = torch.topk(p, k=2).values
    return top2[0] - top2[1]

def active_area(p, ratio=0.3):
    return (p > p.max() * ratio).float().mean()

def js_divergence(p, q):
    m = 0.5 * (p + q)
    return 0.5 * kl(p, m) + 0.5 * kl(q, m)

def target_mass(p, patch_boxes, bbox):
    mask = patch_intersects_bbox(patch_boxes, bbox)
    return p[mask].sum()

